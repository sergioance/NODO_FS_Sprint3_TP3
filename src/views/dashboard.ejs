<h1 class="text-3xl font-bold text-center mb-12"><u>DASHBOARD SUPERHEROES</u></h1>

<div class="flex justify-self-start mb-4">
  <a href="/api/heroes/formulario"
    class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-500 transition">Nuevo Superhéroe</a>
</div>

<% if (!superheroes || superheroes.length === 0) { %>
  <p class="text-start text-gray-500">No hay superhéroes registrados.</p>
<% } else { %>
  <div class="overflow-x-auto bg-sky-100 rounded-lg shadow">
    <table class="w-full table-auto">
      <thead class="bg-blue-400 text-gray-900 uppercase text-sm">
        <tr>
          <th class="py-3 px-6 text-center">Superhéroe</th>
          <th class="py-3 px-6 text-center">Nombre Real</th>
          <th class="py-3 px-6 text-center">Edad</th>
          <th class="py-3 px-6 text-center">Planeta</th>
          <th class="py-3 px-6 text-center">Debilidad</th>
          <th class="py-3 px-6 text-center">Poderes</th>
          <th class="py-3 px-6 text-center">Aliados</th>
          <th class="py-3 px-6 text-center">Enemigos</th>
          <th class="py-3 px-6 text-center">Acción</th>
        </tr>
      </thead>
      <tbody class="text-gray-700">
        <% superheroes.forEach(superhero => { %>
          <tr class="border-b border-gray-200 hover:bg-gray-100">
            <td class="py-3 px-10 whitespace-nowrap text-center"><%= superhero.nombreSuperheroe %></td>
            <td class="py-3 px-10 whitespace-nowrap text-center"><%= superhero.nombreReal %></td>
            <td class="py-3 px-6"><%= superhero.edad %></td>
            <td class="py-3 px-6"><%= superhero.planetaOrigen %></td>
            <td class="py-3 px-10"><%= superhero.debilidad %></td>
            <td class="py-3 px-6"><%= Array.isArray(superhero.poderes) ? superhero.poderes.join(', ') : superhero.poderes %></td>
            <td class="py-3 px-6"><%= Array.isArray(superhero.aliados) ? superhero.aliados.join(', ') : superhero.aliados %></td>
            <td class="py-3 px-6"><%= Array.isArray(superhero.enemigos) ? superhero.enemigos.join(', ') : superhero.enemigos %></td>
            <td class="py-3 px-6 text-center">
              <div class="flex justify-center gap-2">
                <a href="/api/heroes/<%= superhero._id %>/formularioEdit"
                  class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-500 transition">Editar</a>
               <form class="delete-form" action="/api/heroes/<%= superhero._id %>?_method=DELETE" method="POST">
                  <button type="submit"
                    class="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-500 transition">Eliminar</button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  // helper para escapar HTML y evitar inyección
  const escapeHtml = (unsafe) => {
    return unsafe
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');
  };

  document.querySelectorAll('.delete-form').forEach(form => {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      const nombre = this.closest('tr').querySelector('td')?.textContent?.trim() || 'este registro';
      const safeNombre = escapeHtml(nombre);
      Swal.fire({
        html: `¿Estás seguro de que deseas eliminar a <strong>${safeNombre}</strong> de la base de datos?`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#3085d6',
        cancelButtonColor: '#d33',
        confirmButtonText: 'Sí, eliminar',
        cancelButtonText: 'Cancelar'
      }).then((result) => {
        if (result.isConfirmed) {
          form.submit();
        }
      });
    });
  });
</script>